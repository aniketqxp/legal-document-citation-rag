# Files and directories to exclude from Docker build contexts
# This applies to ALL services unless overridden per-service

# Reference repositories — large, never needed in images
reference_materials/

# Git history
.git/
.gitignore

# Node modules (frontend service has its own)
node_modules/
.next/

# Python caches
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Virtual environments
.venv/
venv/

# Environment files — never bake secrets into images
.env
.env.*

# Editor / OS artifacts
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local uploads (served via MinIO, not bundled in the image)
uploads/
storage/
