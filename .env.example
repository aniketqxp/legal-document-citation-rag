# ============================================================
# legal-document-citation-rag — Environment Variables
# Copy this file to .env and fill in the values.
# DO NOT commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=local

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=legal_document_citation_rag

# ── Redis (Celery broker) ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changethis
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ── First Superuser (created on first startup) ────────────────
FIRST_SUPERUSER=admin@local.ai
FIRST_SUPERUSER_PASSWORD=changethis

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── MinIO (S3-compatible storage) ────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changethis
MINIO_BUCKET=legal-document-citation-rag-documents
MINIO_USE_SSL=false

# ── OpenRouter (LLM + Embeddings) ────────────────────────────
# Sign up at https://openrouter.ai and create an API key.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Embedding Model ───────────────────────────────────────────
# text-embedding-3-small produces 1536-dim vectors.
# This MUST match the pgvector column dimension in DocumentChunk.
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── LLM Models (via OpenRouter) ───────────────────────────────
# Fast model: used during ingestion for table summarization / chunk enrichment
FAST_LLM_MODEL=google/gemini-flash-1.5

# Reasoning model: used for user queries with citation injection
REASONING_LLM_MODEL=google/gemini-pro-1.5

# Query model: used by the chat endpoint
QUERY_LLM_MODEL=google/gemini-2.5-flash

# ── Frontend ──────────────────────────────────────────────────
# URL the browser uses to reach the FastAPI backend
VITE_API_URL=http://localhost:8000/api/v1
